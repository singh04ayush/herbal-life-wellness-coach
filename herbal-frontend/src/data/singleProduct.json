                    "image": {
                        "altText": "Herbalife Formula 1 Nutritional Shake Mix Mango 750g Nutritional Information",
                        "ariaLabel": "Herbalife Formula 1 Nutritional Shake Mix Mango 750g Nutritional Information",
                        "desktopImage": {
                            "_path": "/content/dam/market-reusable-assets/emea/india/images/nutritional-facts/pn-406k-in.jpg",
                            "_publishUrl": "https://www.herbalife.com/assets/market-reusable-assets/emea/india/images/nutritional-facts/pn-406k-in.jpg"
